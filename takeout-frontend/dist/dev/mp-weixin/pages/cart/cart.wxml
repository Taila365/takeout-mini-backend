<view class="container data-v-4a5ab35b"><view wx:if="{{a}}" class="empty-cart data-v-4a5ab35b"><image src="/static/images/empty-cart.png" class="empty-img data-v-4a5ab35b"/><text class="empty-text data-v-4a5ab35b">购物车是空的</text><button class="go-shopping data-v-4a5ab35b" bindtap="{{b}}">去逛逛</button></view><view wx:else class="cart-list data-v-4a5ab35b"><view wx:for="{{c}}" wx:for-item="item" wx:key="j" class="cart-item data-v-4a5ab35b"><checkbox class="data-v-4a5ab35b" checked="{{item.a}}" bindtap="{{item.b}}"/><image src="{{item.c}}" class="item-img data-v-4a5ab35b"/><view class="item-info data-v-4a5ab35b"><view class="item-name data-v-4a5ab35b">{{item.d}}</view><view class="item-price data-v-4a5ab35b">¥{{item.e}}</view><view class="item-actions data-v-4a5ab35b"><view class="quantity-control data-v-4a5ab35b"><text class="btn-minus data-v-4a5ab35b" bindtap="{{item.f}}">-</text><text class="quantity data-v-4a5ab35b">{{item.g}}</text><text class="btn-plus data-v-4a5ab35b" bindtap="{{item.h}}">+</text></view><text class="btn-delete data-v-4a5ab35b" bindtap="{{item.i}}">删除</text></view></view></view></view><view wx:if="{{d}}" class="cart-footer data-v-4a5ab35b"><view class="select-all data-v-4a5ab35b" bindtap="{{f}}"><checkbox class="data-v-4a5ab35b" checked="{{e}}"/><text class="data-v-4a5ab35b">全选</text></view><view class="cart-total data-v-4a5ab35b"><text class="total-label data-v-4a5ab35b">合计:</text><text class="total-price data-v-4a5ab35b">¥{{g}}</text></view><view class="btn-submit data-v-4a5ab35b" bindtap="{{i}}"> 结算({{h}}) </view></view></view>